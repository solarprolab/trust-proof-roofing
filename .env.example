# Supabase (Settings → API in your Supabase project)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
# Resend (resend.com → API Keys)
RESEND_API_KEY=re_your_api_key_here
# Resend inbound webhook signature secret (resend.com → Webhooks → Signing Secret)
RESEND_WEBHOOK_SECRET=whsec_your_signing_secret_here
# Anthropic (claude.ai → API Keys)
ANTHROPIC_API_KEY=sk-ant-your_api_key_here
